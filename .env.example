# FamilyShield — Environment Variables Template
# Copy to .env and fill in values
# NEVER commit .env to git

# OCI
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxx
OCI_NAMESPACE=xxxx

# Cloudflare
