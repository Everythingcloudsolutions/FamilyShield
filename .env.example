NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI / LLM
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Platform APIs
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
