# FamilyShield — Environment Variables Template
# Copy to .env and fill in values
# NEVER commit .env to git

# OCI
OCI_TENANCY_OCID=ocid1.tenancy.oc1..xxxx
OCI_NAMESPACE=xxxx

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Portal → API URL (used for /cert download link)
# Dev/prod: https://api-dev.everythingcloud.ca or https://api.everythingcloud.ca
# Local: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Headscale Admin (VPN admin UI)
# No server-side secrets are required for headscale-admin; the browser stores the API key locally.
# Use the headscale-admin UI on /admin after deployment.
# AI / LLM
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# Platform APIs
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# App
ADGUARD_ADMIN_PASSWORD=
NODE_ENV=development

# Portal auth scaffold (enable for protected routes)
PORTAL_BASIC_AUTH_ENABLED=false
PORTAL_BASIC_AUTH_USERNAME=
PORTAL_BASIC_AUTH_PASSWORD=
